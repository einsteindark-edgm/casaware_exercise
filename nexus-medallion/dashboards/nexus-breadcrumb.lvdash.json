{
  "datasets": [
    {
      "name": "trace_options",
      "displayName": "Available trace IDs (24h)",
      "queryLines": [
        "SELECT\n  metadata.trace_id AS trace_id,\n  MIN(created_at)   AS first_seen,\n  MAX(created_at)   AS last_seen,\n  COUNT(*)          AS event_count,\n  ANY_VALUE(expense_id) AS expense_id\nFROM nexus_dev.silver.expense_events\nWHERE metadata.trace_id IS NOT NULL\n  AND created_at >= current_timestamp() - INTERVAL 24 HOURS\nGROUP BY metadata.trace_id\nORDER BY last_seen DESC\nLIMIT 200"
      ]
    },
    {
      "name": "breadcrumb",
      "displayName": "Breadcrumb timeline (filtered by trace_id)",
      "queryLines": [
        "WITH events AS (\n  SELECT\n    expense_id,\n    event_type,\n    actor.type   AS actor_type,\n    actor.id     AS actor_id,\n    workflow_id,\n    metadata.trace_id AS trace_id,\n    created_at,\n    LAG(created_at) OVER (\n      PARTITION BY expense_id ORDER BY created_at\n    ) AS prev_at\n  FROM nexus_dev.silver.expense_events\n  WHERE metadata.trace_id = :trace_id\n)\nSELECT\n  created_at,\n  event_type,\n  actor_type,\n  actor_id,\n  workflow_id,\n  expense_id,\n  CASE\n    WHEN prev_at IS NULL THEN NULL\n    ELSE (UNIX_TIMESTAMP(created_at) - UNIX_TIMESTAMP(prev_at))\n  END AS stage_duration_sec\nFROM events\nORDER BY created_at ASC"
      ],
      "parameters": [
        {
          "keyword": "trace_id",
          "displayName": "trace_id",
          "dataType": "STRING"
        }
      ]
    }
  ],
  "pages": [
