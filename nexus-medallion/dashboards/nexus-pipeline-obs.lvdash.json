{
  "datasets": [
    {
      "name": "d_approval_ratio",
      "displayName": "Approval ratio",
      "queryLines": [
        "SELECT ROUND(100.0 * SUM(CASE WHEN status='approved' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 1) AS approval_pct\n",
        "FROM nexus_dev.silver.expenses\n",
        "WHERE created_at >= current_date() - INTERVAL 7 DAY\n"
      ]
    },
    {
      "name": "d_hitl_pending",
      "displayName": "HITL pending",
      "queryLines": [
        "SELECT COUNT(*) AS pending\n",
        "FROM nexus_dev.silver.hitl_events\n",
        "WHERE status = 'pending'\n"
      ]
    },
    {
      "name": "d_ocr_low_conf",
      "displayName": "OCR low-confidence",
      "queryLines": [
        "SELECT COUNT(*) AS low_conf\n",
        "FROM nexus_dev.silver.ocr_extractions\n",
        "WHERE avg_confidence < 80\n",
        "  AND extracted_at >= current_date() - INTERVAL 7 DAY\n"
      ]
    },
    {
      "name": "d_stuck_processing",
      "displayName": "Workflows stuck",
      "queryLines": [
        "SELECT COUNT(*) AS stuck\n",
        "FROM nexus_dev.silver.expenses\n",
        "WHERE status = 'processing'\n",
        "  AND updated_at < current_timestamp() - INTERVAL 10 MINUTE\n"
      ]
    },
    {
      "name": "d_expenses_by_day_status",
      "displayName": "Expenses por día y status",
      "queryLines": [
        "SELECT DATE_TRUNC('day', created_at) AS day,\n",
        "       status,\n",
        "       COUNT(*) AS n\n",
        "FROM   nexus_dev.silver.expenses\n",
        "WHERE  created_at >= current_date() - INTERVAL 14 DAY\n",
        "GROUP BY 1, 2\n",
        "ORDER BY 1\n"
      ]
    },
    {
      "name": "d_freshness",
      "displayName": "Frescura bronze → silver → gold",
      "queryLines": [
        "WITH b AS (\n",
        "  SELECT expense_id, MAX(__source_ts_ms) AS bronze_ts_ms\n",
        "  FROM nexus_dev.bronze.mongodb_cdc_expenses\n",
        "  GROUP BY expense_id\n",
        "),\n",
        "s AS (\n",
        "  SELECT expense_id, updated_at AS silver_ts, status\n",
        "  FROM nexus_dev.silver.expenses\n",
        "),\n",
        "g AS (\n",
        "  SELECT expense_id, approved_at AS gold_ts\n",
        "  FROM nexus_dev.gold.expense_audit\n",
        ")\n",
        "SELECT b.expense_id,\n",
        "       TIMESTAMP_MILLIS(b.bronze_ts_ms) AS bronze_latest,\n",
        "       s.status,\n",
        "       s.silver_ts,\n",
        "       g.gold_ts,\n",
        "       (unix_millis(s.silver_ts) - b.bronze_ts_ms)/1000.0 AS bronze_to_silver_sec,\n",
        "       (unix_millis(g.gold_ts) - unix_millis(s.silver_ts))/1000.0 AS silver_to_gold_sec\n",
        "FROM   b\n",
        "LEFT JOIN s USING(expense_id)\n",
        "LEFT JOIN g USING(expense_id)\n",
        "ORDER BY bronze_latest DESC\n",
        "LIMIT 50\n"
      ]
    },
    {
      "name": "d_last_expenses",
      "displayName": "Últimos 20 expenses",
      "queryLines": [
        "SELECT expense_id, tenant_id, status, amount, currency, vendor, created_at, updated_at\n",
        "FROM   nexus_dev.silver.expenses\n",
        "ORDER BY created_at DESC\n",
        "LIMIT 20\n"
      ]
    },
    {
      "name": "d_hitl_discrepancies",
      "displayName": "Campos disputados en HITL",
      "queryLines": [
        "SELECT field, COUNT(*) AS n\n",
        "FROM   nexus_dev.silver.hitl_events\n",
        "LATERAL VIEW EXPLODE(discrepancy_fields) df AS field\n",
        "WHERE  created_at >= current_date() - INTERVAL 30 DAY\n",
        "GROUP BY field\n",
        "ORDER BY n DESC\n"
      ]
    },
    {
      "name": "d_pipeline_fail_24h",
      "displayName": "Pipeline fails 24h",
      "queryLines": [
        "SELECT COUNT(*) AS failed\n",
        "FROM   system.lakeflow.pipeline_update_timeline t\n",
        "JOIN   system.lakeflow.pipelines p ON t.pipeline_id = p.pipeline_id\n",
        "WHERE  p.name LIKE '%nexus%'\n",
        "  AND  t.result_state = 'FAILED'\n",
        "  AND  t.period_start_time >= current_timestamp() - INTERVAL 24 HOUR\n"
      ]
    },
    {
      "name": "d_pipeline_success_rate",
      "displayName": "Success rate 7d",
      "queryLines": [
        "SELECT ROUND(100.0*SUM(CASE WHEN result_state='COMPLETED' THEN 1 ELSE 0 END)/NULLIF(COUNT(*),0), 1) AS pct\n",
        "FROM   system.lakeflow.pipeline_update_timeline t\n",
        "JOIN   system.lakeflow.pipelines p ON t.pipeline_id = p.pipeline_id\n",
        "WHERE  p.name LIKE '%nexus%'\n",
        "  AND  t.period_start_time >= current_timestamp() - INTERVAL 7 DAY\n"
      ]
    },
    {
      "name": "d_pipeline_runs_timeline",
      "displayName": "Pipeline runs timeline",
      "queryLines": [
        "SELECT DATE_TRUNC('hour', t.period_start_time) AS hour,\n",
        "       CASE WHEN p.name LIKE '%bronze%' THEN 'bronze'\n",
        "            WHEN p.name LIKE '%silver%' THEN 'silver'\n",
        "            WHEN p.name LIKE '%gold%'   THEN 'gold'\n",
        "            ELSE 'other' END                AS layer,\n",
        "       t.result_state,\n",
        "       COUNT(*)                              AS n\n",
        "FROM   system.lakeflow.pipeline_update_timeline t\n",
        "JOIN   system.lakeflow.pipelines p ON t.pipeline_id = p.pipeline_id\n",
        "WHERE  p.name LIKE '%nexus%'\n",
        "  AND  t.period_start_time >= current_timestamp() - INTERVAL 24 HOUR\n",
        "GROUP BY 1, 2, 3\n",
        "ORDER BY 1\n"
      ]
    },
    {
      "name": "d_last_pipeline_runs",
      "displayName": "Últimos 30 runs",
      "queryLines": [
        "SELECT p.name                                                       AS pipeline,\n",
        "       t.update_id,\n",
        "       t.result_state,\n",
        "       t.period_start_time,\n",
        "       t.period_end_time,\n",
        "       (unix_timestamp(t.period_end_time) - unix_timestamp(t.period_start_time)) AS duration_sec\n",
        "FROM   system.lakeflow.pipeline_update_timeline t\n",
        "JOIN   system.lakeflow.pipelines p ON t.pipeline_id = p.pipeline_id\n",
        "WHERE  p.name LIKE '%nexus%'\n",
        "ORDER BY t.period_start_time DESC\n",
        "LIMIT  30\n"
      ]
    },
    {
      "name": "d_pipeline_errors",
      "displayName": "Últimos errores (event_log)",
      "queryLines": [
        "SELECT 'gold' AS pipeline, timestamp, event_type,\n",
        "       LEFT(regexp_replace(message, '[\\\\n\\\\r\\\\t]+', ' '), 250) AS message\n",
        "FROM   event_log('caf4284f-2d27-429e-99ce-2506597b11c1') WHERE level='ERROR'\n",
        "UNION ALL\n",
        "SELECT 'silver', timestamp, event_type,\n",
        "       LEFT(regexp_replace(message, '[\\\\n\\\\r\\\\t]+', ' '), 250)\n",
        "FROM   event_log('ebf90ff0-d34e-43f6-b62d-8f4e7e74f71d') WHERE level='ERROR'\n",
        "UNION ALL\n",
        "SELECT 'bronze', timestamp, event_type,\n",
        "       LEFT(regexp_replace(message, '[\\\\n\\\\r\\\\t]+', ' '), 250)\n",
        "FROM   event_log('e65111c9-353f-45ad-9768-c2a6c22e9110') WHERE level='ERROR'\n",
        "ORDER BY timestamp DESC LIMIT 15\n"
      ]
    },
    {
      "name": "d_layer_funnel",
      "displayName": "Funnel bronze → silver → gold",
      "queryLines": [
        "SELECT 'bronze' AS layer, COUNT(*) AS n, 1 AS sort_order FROM nexus_dev.bronze.mongodb_cdc_expenses\n",
        "UNION ALL\n",
        "SELECT 'silver',          COUNT(*),      2                 FROM nexus_dev.silver.expenses\n",
        "UNION ALL\n",
        "SELECT 'gold',            COUNT(*),      3                 FROM nexus_dev.gold.expense_audit\n",
        "ORDER BY sort_order\n"
      ]
    }
  ],
