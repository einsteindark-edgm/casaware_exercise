# ─── Environment ────────────────────────────────────────────────────────────
ENV=dev
AWS_REGION=us-east-1

# ─── Auth mode ──────────────────────────────────────────────────────────────
# "prod" validates JWTs against Cognito JWKS. "dev" accepts JWTs signed with
# DEV_JWT_SECRET (HS256) — use only for local development.
AUTH_MODE=dev
DEV_JWT_SECRET=dev-secret-change-me

# ─── Cognito (only required when AUTH_MODE=prod) ────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXX
COGNITO_APP_CLIENT_ID=xxxxx
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXX/.well-known/jwks.json

# ─── Temporal ───────────────────────────────────────────────────────────────
# TEMPORAL_MODE=real connects to TEMPORAL_HOST. TEMPORAL_MODE=fake uses
# an in-memory FakeTemporalClient (useful when workers aren't built yet).
TEMPORAL_MODE=real
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_TLS=false

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/?replicaSet=rs0&directConnection=true
MONGODB_DB=nexus_dev

# ─── S3 ─────────────────────────────────────────────────────────────────────
S3_RECEIPTS_BUCKET=nexus-receipts-dev
S3_TEXTRACT_OUTPUT_BUCKET=nexus-textract-output-dev
# For LocalStack / dev
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute

# ─── Observability ──────────────────────────────────────────────────────────
XRAY_ENABLED=false
LOG_LEVEL=INFO

# ─── Feature flags ──────────────────────────────────────────────────────────
EXPENSE_HISTORY_CACHE=false
