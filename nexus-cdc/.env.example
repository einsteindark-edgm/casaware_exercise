MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=nexus_dev

AWS_REGION=us-east-1
S3_BUCKET=nexus-dev-edgm-cdc
DDB_OFFSETS_TABLE=nexus-dev-edgm-cdc-offsets

BATCH_MAX_EVENTS=200
BATCH_MAX_SECONDS=30
IDLE_FLUSH_SECONDS=300

LOG_LEVEL=INFO
BOOTSTRAP_ON_EMPTY_OFFSET=true

# For LocalStack in dev only — leave unset in prod.
# AWS_ENDPOINT_URL=http://localhost:4566
