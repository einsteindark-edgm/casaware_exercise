# ─── Environment ────────────────────────────────────────────────────────────
ENV=dev
AWS_REGION=us-east-1

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=

# Task queue for this worker process. Use "all" in dev to run one worker that
# owns every queue. In prod, run one container per queue:
#   nexus-orchestrator-tq | nexus-ocr-tq | nexus-databricks-tq | nexus-rag-tq
TASK_QUEUE=all

WORKER_MAX_CONCURRENT_ACTIVITIES=20
WORKER_MAX_CONCURRENT_WORKFLOW_TASKS=50

# ─── Shared dependencies (must match backend/.env) ──────────────────────────
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGODB_DB=nexus_dev
REDIS_URL=redis://localhost:6379/0
REDIS_TLS=false

# ─── S3 / AWS credentials ───────────────────────────────────────────────────
# For local dev against LocalStack:
#   AWS_ACCESS_KEY_ID=test
#   AWS_SECRET_ACCESS_KEY=test
#   AWS_ENDPOINT_URL=http://localhost:4566
# For local dev against REAL AWS (workers writing to real S3):
#   Copy the access keys from `terraform output worker_access_key_id`
#   and `terraform output worker_secret_access_key`.
#   Leave AWS_ENDPOINT_URL empty so boto3 hits the real regional endpoint.
# For production (ECS task): do NOT set these — boto3 picks up the task
# role credentials via IMDSv2 automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_RECEIPTS_BUCKET=nexus-receipts-dev
S3_TEXTRACT_OUTPUT_BUCKET=nexus-textract-output-dev
AWS_ENDPOINT_URL=http://localhost:4566

# ─── Fake providers ─────────────────────────────────────────────────────────
# Global switch. true → stub every external provider (Textract / Bedrock /
# Vector Search / Databricks SQL). false (default) → require real credentials
# for every real call site. On `nexus-rag-tq` the worker preflight will refuse
# to start if any real provider has missing credentials (fail loud).
FAKE_PROVIDERS=false

# Per-provider overrides. When unset, each follows FAKE_PROVIDERS. Lets you
# unlock providers independently as credentials/quotas become available.
# FAKE_TEXTRACT=false
# FAKE_BEDROCK=false
# FAKE_VECTOR_SEARCH=false
# FAKE_SQL_SEARCH=false

# Controls the fake Textract output vs user-reported data (only when
# FAKE_PROVIDERS=true):
#   auto  → hash-derived small offset (may or may not trigger HITL)
#   force → guaranteed discrepancy > tolerance → HITL always fires
#   never → OCR matches user exactly → happy path (no HITL)
FAKE_HITL_MODE=auto

# ─── Auditor source ─────────────────────────────────────────────────────────
# mongo → read user-reported data from the backend's MongoDB `expenses`.
# databricks → read from silver.expenses (requires Databricks creds below).
AUDIT_SOURCE=mongo

# ─── Databricks (required when FAKE_PROVIDERS=false or AUDIT_SOURCE=databricks) ─
# For the RAG chat (nexus-rag-tq) ALL of the Vector Search + SQL values below
# are required. The setup notebook is at
# `nexus-medallion/src/vector/setup_vector_search.py`; run it once before
# starting the worker in real mode.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=nexus_dev
DATABRICKS_VS_ENDPOINT=nexus-vs-dev
DATABRICKS_VS_INDEX=nexus_dev.vector.expense_chunks_index

# Vector search backend: "local" (default) or "managed".
# local   → cosine over the embedding column on gold.expense_chunks (no
#           managed index needed). Works on any Databricks tier.
# managed → Mosaic AI Vector Search managed index (use only if your
#           workspace supports Delta Sync auto-pipelines).
VECTOR_BACKEND=local

# ─── LLM ────────────────────────────────────────────────────────────────────
# Cross-region inference profile ID. Default: Amazon Nova Pro (US geo profile).
# Nova es first-party AWS → cero formulario de acceso, cero verificación.
# Converse API + tool use son idénticos a Claude en shape.
#
# Para usar Claude Sonnet 4.6 en vez de Nova (requiere FTU form de Anthropic):
#   BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
