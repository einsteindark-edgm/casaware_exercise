# ─── Environment ────────────────────────────────────────────────────────────
ENV=dev
AWS_REGION=us-east-1

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=

# Task queue for this worker process. Use "all" in dev to run one worker that
# owns every queue. In prod, run one container per queue:
#   nexus-orchestrator-tq | nexus-ocr-tq | nexus-databricks-tq | nexus-rag-tq
TASK_QUEUE=all

WORKER_MAX_CONCURRENT_ACTIVITIES=20
WORKER_MAX_CONCURRENT_WORKFLOW_TASKS=50

# ─── Shared dependencies (must match backend/.env) ──────────────────────────
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGODB_DB=nexus_dev
REDIS_URL=redis://localhost:6379/0
REDIS_TLS=false

# ─── S3 (LocalStack in dev) ─────────────────────────────────────────────────
S3_RECEIPTS_BUCKET=nexus-receipts-dev
S3_TEXTRACT_OUTPUT_BUCKET=nexus-textract-output-dev
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─── Fake providers ─────────────────────────────────────────────────────────
# true → stub Textract / Bedrock / Vector Search with deterministic data.
# false → require real boto3/Anthropic/Databricks credentials.
FAKE_PROVIDERS=true

# Controls the fake Textract output vs user-reported data (only when
# FAKE_PROVIDERS=true):
#   auto  → hash-derived small offset (may or may not trigger HITL)
#   force → guaranteed discrepancy > tolerance → HITL always fires
#   never → OCR matches user exactly → happy path (no HITL)
FAKE_HITL_MODE=auto

# ─── Auditor source ─────────────────────────────────────────────────────────
# mongo → read user-reported data from the backend's MongoDB `expenses`.
# databricks → read from silver.expenses (requires Databricks creds below).
AUDIT_SOURCE=mongo

# ─── Databricks (only when FAKE_PROVIDERS=false or AUDIT_SOURCE=databricks) ─
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=nexus_dev
DATABRICKS_VS_ENDPOINT=
DATABRICKS_VS_INDEX=

# ─── LLM ────────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20250514-v1:0
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
