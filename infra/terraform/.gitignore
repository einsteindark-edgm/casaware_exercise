# Local .terraform directories
.terraform/

# State files — local backend; never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plans
tfplan
*.tfplan

# CLI config
.terraformrc
terraform.rc

# Local variable overrides (tokens, secrets)
terraform.tfvars
*.auto.tfvars
